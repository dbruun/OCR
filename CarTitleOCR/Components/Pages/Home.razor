@page "/"
@rendermode InteractiveServer
@using CarTitleOCR.Models
@inject IOcrService OcrService
@inject IFraudDetectionService FraudDetectionService

<PageTitle>Bicycle Title Registration</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-4">
        <span class="fs-1 me-3">🚲</span>
        <div>
            <h1 class="mb-0">Bicycle Title Application</h1>
            <p class="text-muted mb-0">Upload an out-of-state title or enter information manually</p>
        </div>
    </div>

    <!-- Document Upload Section -->
    <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📄 Upload Title Document (OCR Auto-Fill)</h5>
        </div>
        <div class="card-body">
            <p class="text-muted small">
                Upload a scan or photo of the bicycle title. Microsoft Azure AI Document Intelligence
                will automatically extract and populate the form fields below.
                Accepted formats: PDF, JPEG, PNG, TIFF.
            </p>

            <InputFile OnChange="HandleFileUpload" accept=".pdf,.jpg,.jpeg,.png,.tiff,.tif"
                       class="form-control mb-3" disabled="@_isProcessing" />

            @if (_isProcessing)
            {
                <div class="d-flex align-items-center text-primary">
                    <div class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></div>
                    <span>Analyzing document with Azure AI Document Intelligence…</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(_uploadMessage))
            {
                <div class="alert @_uploadAlertClass mt-2 mb-0" role="alert">
                    @_uploadMessage
                </div>
            }
        </div>
    </div>

    @if (_fraudCheck?.Flags.Any() == true)
    {
        <div class="alert @(_fraudCheck.RequiresManualReview ? "alert-warning" : "alert-info") mb-4" role="alert">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <strong>Fraud review signals detected</strong>
                    <div class="small mt-1">Risk score: @_fraudCheck.Score</div>
                </div>
                @if (_fraudCheck.RequiresManualReview)
                {
                    <span class="badge bg-warning text-dark">Manual review recommended</span>
                }
            </div>

            <ul class="mb-0 mt-2">
                @foreach (var flag in _fraudCheck.Flags)
                {
                    <li>@flag</li>
                }
            </ul>
        </div>
    }

    <!-- Title Entry Form -->
    <EditForm Model="@_titleModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <!-- Bicycle Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">🔧 Bicycle Information</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            VIN @OcrBadge(nameof(CarTitleModel.Vin), _titleModel.Vin)
                        </label>
                        <InputText @bind-Value="_titleModel.Vin" class="form-control font-monospace"
                                   placeholder="e.g. WTU19C00423" maxlength="17" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            Year @OcrBadge(nameof(CarTitleModel.Year), _titleModel.Year)
                        </label>
                        <InputText @bind-Value="_titleModel.Year" class="form-control"
                                   placeholder="e.g. 2022" maxlength="4" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            Make @OcrBadge(nameof(CarTitleModel.Make), _titleModel.Make)
                        </label>
                        <InputText @bind-Value="_titleModel.Make" class="form-control"
                                   placeholder="e.g. Trek" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">
                            Model @OcrBadge(nameof(CarTitleModel.BicycleModel), _titleModel.BicycleModel)
                        </label>
                        <InputText @bind-Value="_titleModel.BicycleModel" class="form-control"
                                   placeholder="e.g. FX3" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Bicycle Type @OcrBadge(nameof(CarTitleModel.BodyStyle), _titleModel.BodyStyle)
                        </label>
                        <InputSelect @bind-Value="_titleModel.BodyStyle" class="form-select">
                            <option value="">-- Select --</option>
                            <option>Road</option>
                            <option>Mountain</option>
                            <option>Hybrid</option>
                            <option>City/Commuter</option>
                            <option>BMX</option>
                            <option>Electric</option>
                            <option>Cargo</option>
                            <option>Other</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Color @OcrBadge(nameof(CarTitleModel.Color), _titleModel.Color)
                        </label>
                        <InputText @bind-Value="_titleModel.Color" class="form-control"
                                   placeholder="e.g. Silver" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Odometer Reading @OcrBadge(nameof(CarTitleModel.Odometer), _titleModel.Odometer)
                        </label>
                        <InputText @bind-Value="_titleModel.Odometer" class="form-control"
                                   placeholder="e.g. 45000" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Title Number @OcrBadge(nameof(CarTitleModel.TitleNumber), _titleModel.TitleNumber)
                        </label>
                        <InputText @bind-Value="_titleModel.TitleNumber" class="form-control"
                                   placeholder="Title document number" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Issuing State @OcrBadge(nameof(CarTitleModel.StateOfIssuance), _titleModel.StateOfIssuance)
                        </label>
                        <InputText @bind-Value="_titleModel.StateOfIssuance" class="form-control"
                                   placeholder="e.g. CA, TX, NY" maxlength="2" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Previous Owner -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">👤 Previous Owner (Seller / Transferor)</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Full Name @OcrBadge(nameof(CarTitleModel.PreviousOwnerName), _titleModel.PreviousOwnerName)
                        </label>
                        <InputText @bind-Value="_titleModel.PreviousOwnerName" class="form-control"
                                   placeholder="Full legal name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Street Address @OcrBadge(nameof(CarTitleModel.PreviousOwnerAddress), _titleModel.PreviousOwnerAddress)
                        </label>
                        <InputText @bind-Value="_titleModel.PreviousOwnerAddress" class="form-control"
                                   placeholder="Street address" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            City @OcrBadge(nameof(CarTitleModel.PreviousOwnerCity), _titleModel.PreviousOwnerCity)
                        </label>
                        <InputText @bind-Value="_titleModel.PreviousOwnerCity" class="form-control"
                                   placeholder="City" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            State @OcrBadge(nameof(CarTitleModel.PreviousOwnerState), _titleModel.PreviousOwnerState)
                        </label>
                        <InputText @bind-Value="_titleModel.PreviousOwnerState" class="form-control"
                                   placeholder="State" maxlength="2" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            ZIP Code @OcrBadge(nameof(CarTitleModel.PreviousOwnerZip), _titleModel.PreviousOwnerZip)
                        </label>
                        <InputText @bind-Value="_titleModel.PreviousOwnerZip" class="form-control"
                                   placeholder="ZIP" maxlength="10" />
                    </div>
                </div>
            </div>
        </div>

        <!-- New Owner -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">🏠 New Owner (Buyer / Transferee)</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Full Name @OcrBadge(nameof(CarTitleModel.NewOwnerName), _titleModel.NewOwnerName)
                        </label>
                        <InputText @bind-Value="_titleModel.NewOwnerName" class="form-control"
                                   placeholder="Full legal name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Street Address @OcrBadge(nameof(CarTitleModel.NewOwnerAddress), _titleModel.NewOwnerAddress)
                        </label>
                        <InputText @bind-Value="_titleModel.NewOwnerAddress" class="form-control"
                                   placeholder="Street address" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            City @OcrBadge(nameof(CarTitleModel.NewOwnerCity), _titleModel.NewOwnerCity)
                        </label>
                        <InputText @bind-Value="_titleModel.NewOwnerCity" class="form-control"
                                   placeholder="City" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            State @OcrBadge(nameof(CarTitleModel.NewOwnerState), _titleModel.NewOwnerState)
                        </label>
                        <InputText @bind-Value="_titleModel.NewOwnerState" class="form-control"
                                   placeholder="State" maxlength="2" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">
                            ZIP Code @OcrBadge(nameof(CarTitleModel.NewOwnerZip), _titleModel.NewOwnerZip)
                        </label>
                        <InputText @bind-Value="_titleModel.NewOwnerZip" class="form-control"
                                   placeholder="ZIP" maxlength="10" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Transaction Details -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">💰 Transaction &amp; Lienholder</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Purchase Price @OcrBadge(nameof(CarTitleModel.PurchasePrice), _titleModel.PurchasePrice)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <InputText @bind-Value="_titleModel.PurchasePrice" class="form-control"
                                       placeholder="0.00" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">
                            Purchase Date @OcrBadge(nameof(CarTitleModel.PurchaseDate), _titleModel.PurchaseDate)
                        </label>
                        <InputText @bind-Value="_titleModel.PurchaseDate" class="form-control"
                                   placeholder="MM/DD/YYYY" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Lienholder Name @OcrBadge(nameof(CarTitleModel.LienholderName), _titleModel.LienholderName)
                        </label>
                        <InputText @bind-Value="_titleModel.LienholderName" class="form-control"
                                   placeholder="Bank or financial institution (if any)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            Lienholder Address @OcrBadge(nameof(CarTitleModel.LienholderAddress), _titleModel.LienholderAddress)
                        </label>
                        <InputText @bind-Value="_titleModel.LienholderAddress" class="form-control"
                                   placeholder="Lienholder address (if any)" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Submit -->
        <div class="d-flex gap-2 mb-5">
            <button type="submit" class="btn btn-success btn-lg px-4">
                ✅ Submit Application
            </button>
            <button type="button" class="btn btn-outline-secondary btn-lg px-4" @onclick="ClearForm">
                🗑 Clear Form
            </button>
        </div>

        @if (_submitSuccess)
        {
            <div class="alert alert-success" role="alert">
                <strong>Application submitted successfully!</strong> Your bicycle title application has been received.
            </div>
        }
    </EditForm>
</div>

@code {
    private CarTitleModel _titleModel = new();
    private bool _isProcessing;
    private string? _uploadMessage;
    private string _uploadAlertClass = "alert-info";
    private bool _submitSuccess;
    private FraudCheckResult? _fraudCheck;

    private const long MaxFileSizeBytes = 20 * 1024 * 1024; // 20 MB

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _uploadMessage = null;
        _uploadAlertClass = "alert-info";
        _isProcessing = true;
        StateHasChanged();

        try
        {
            var file = e.File;

            if (file.Size > MaxFileSizeBytes)
            {
                _uploadAlertClass = "alert-danger";
                _uploadMessage = $"File is too large ({file.Size / 1024 / 1024} MB). Maximum size is 20 MB.";
                return;
            }

            using var ms = new MemoryStream();
            await using var stream = file.OpenReadStream(MaxFileSizeBytes);
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            var extracted = await OcrService.ExtractCarTitleFieldsAsync(fileBytes, file.ContentType);
            var hadExtractedValues = HasExtractedValues(extracted);
            MergeExtractedFields(extracted);
            _fraudCheck = FraudDetectionService.Evaluate(_titleModel, registerVin: hadExtractedValues);

            if (!hadExtractedValues)
            {
                _uploadAlertClass = "alert-danger";
                _uploadMessage = "Document was analyzed, but no supported fields were extracted. Check the OCR output format or try a clearer scan/PDF.";
            }
            else if (_fraudCheck.Flags.Any())
            {
                _uploadAlertClass = _fraudCheck.RequiresManualReview ? "alert-warning" : "alert-info";
                _uploadMessage = _fraudCheck.RequiresManualReview
                    ? "Document analyzed, but fraud review signals were detected during OCR review. Manual review is recommended before submission."
                    : "Document analyzed. Fraud review signals were detected during OCR review; review the warnings below before submission.";
            }
            else
            {
                _uploadAlertClass = "alert-success";
                _uploadMessage = "Document analyzed successfully. Fields have been populated below — please review and correct any values.";
            }
        }
        catch (Exception ex)
        {
            _uploadAlertClass = "alert-danger";
            _fraudCheck = null;
            _uploadMessage = $"Error processing document: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    /// <summary>Only overwrites fields that are currently empty.</summary>
    private void MergeExtractedFields(CarTitleModel extracted)
    {
        _titleModel.Vin ??= extracted.Vin;
        _titleModel.Year ??= extracted.Year;
        _titleModel.Make ??= extracted.Make;
        _titleModel.BicycleModel ??= extracted.BicycleModel;
        _titleModel.BodyStyle ??= extracted.BodyStyle;
        _titleModel.Color ??= extracted.Color;
        _titleModel.Odometer ??= extracted.Odometer;
        _titleModel.TitleNumber ??= extracted.TitleNumber;
        _titleModel.StateOfIssuance ??= extracted.StateOfIssuance;
        _titleModel.PreviousOwnerName ??= extracted.PreviousOwnerName;
        _titleModel.PreviousOwnerAddress ??= extracted.PreviousOwnerAddress;
        _titleModel.PreviousOwnerCity ??= extracted.PreviousOwnerCity;
        _titleModel.PreviousOwnerState ??= extracted.PreviousOwnerState;
        _titleModel.PreviousOwnerZip ??= extracted.PreviousOwnerZip;
        _titleModel.NewOwnerName ??= extracted.NewOwnerName;
        _titleModel.NewOwnerAddress ??= extracted.NewOwnerAddress;
        _titleModel.NewOwnerCity ??= extracted.NewOwnerCity;
        _titleModel.NewOwnerState ??= extracted.NewOwnerState;
        _titleModel.NewOwnerZip ??= extracted.NewOwnerZip;
        _titleModel.PurchasePrice ??= extracted.PurchasePrice;
        _titleModel.PurchaseDate ??= extracted.PurchaseDate;
        _titleModel.LienholderName ??= extracted.LienholderName;
        _titleModel.LienholderAddress ??= extracted.LienholderAddress;
    }

    private static bool HasExtractedValues(CarTitleModel extracted)
        => new[]
        {
            extracted.Vin,
            extracted.Year,
            extracted.Make,
            extracted.BicycleModel,
            extracted.BodyStyle,
            extracted.Color,
            extracted.Odometer,
            extracted.TitleNumber,
            extracted.StateOfIssuance,
            extracted.PreviousOwnerName,
            extracted.PreviousOwnerAddress,
            extracted.PreviousOwnerCity,
            extracted.PreviousOwnerState,
            extracted.PreviousOwnerZip,
            extracted.NewOwnerName,
            extracted.NewOwnerAddress,
            extracted.NewOwnerCity,
            extracted.NewOwnerState,
            extracted.NewOwnerZip,
            extracted.PurchasePrice,
            extracted.PurchaseDate,
            extracted.LienholderName,
            extracted.LienholderAddress,
        }.Any(value => !string.IsNullOrWhiteSpace(value));

    private void HandleSubmit()
    {
        _fraudCheck = FraudDetectionService.Evaluate(_titleModel, registerVin: false);
        _submitSuccess = !_fraudCheck.RequiresManualReview;
    }

    private void ClearForm()
    {
        _titleModel = new CarTitleModel();
        _uploadMessage = null;
        _uploadAlertClass = "alert-info";
        _submitSuccess = false;
        _fraudCheck = null;
    }

    private RenderFragment OcrBadge(string fieldName, string? value) => @<text>
        @if (!string.IsNullOrWhiteSpace(value))
        {
            @if (_fraudCheck?.ReviewFields.Contains(fieldName) == true)
            {
                <span class="badge bg-warning text-dark ms-1" title="Review this OCR value">Review</span>
            }
            else
            {
                <span class="badge bg-success ms-1" title="Auto-filled by OCR">OCR</span>
            }
        }
    </text>;
}

